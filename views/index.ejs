<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #0f0c29, #302b63, #24243e);
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      color: #e0e0e0;
    }

    .card {
      background: rgba(255, 255, 255, 0.06);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 20px;
      padding: 48px 56px;
      text-align: center;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
      max-width: 460px;
      width: 90%;
    }

    .pulse-dot {
      width: 14px;
      height: 14px;
      background: #00e676;
      border-radius: 50%;
      display: inline-block;
      margin-right: 10px;
      animation: pulse 1.4s ease-in-out infinite;
      vertical-align: middle;
      box-shadow: 0 0 10px #00e676;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); opacity: 1; }
      50%      { transform: scale(1.4); opacity: 0.6; }
    }

    h1 {
      font-size: 1.8rem;
      font-weight: 700;
      margin-bottom: 12px;
      letter-spacing: -0.5px;
    }

    .status {
      font-size: 1.1rem;
      color: #00e676;
      font-weight: 600;
      margin-bottom: 20px;
    }

    .meta {
      font-size: 0.85rem;
      color: #9e9e9e;
    }

    .divider {
      width: 60px;
      height: 3px;
      background: linear-gradient(90deg, #7c4dff, #448aff);
      border-radius: 2px;
      margin: 20px auto;
    }

    .emoji { font-size: 2.4rem; margin-bottom: 16px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="emoji">🚀</div>
    <h1><%= title %></h1>
    <div class="divider"></div>
    <p class="status">
      <span class="pulse-dot"></span>Server is <%= status %>
    </p>
    <p class="meta">Last checked: <%= timestamp %></p>
  </div>
</body>
</html>
